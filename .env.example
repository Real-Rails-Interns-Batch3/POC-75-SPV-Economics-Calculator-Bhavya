# SEC EDGAR API Configuration
# Note: SEC requires an identity string in the User-Agent header (e.g., "YourName yourname@domain.com")
SEC_EDGAR_COMPANY_NAME="YourCompanyOrName"
SEC_EDGAR_EMAIL="yourname@domain.com"
SEC_API_KEY=your_real_api_key_here

# Application Context Endpoints
NEXT_PUBLIC_API_URL=http://localhost:8000